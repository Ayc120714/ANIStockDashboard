{
  "name": "ani-stock-mobile",
  "version": "1.2.51",
  "private": true,
  "scripts": {
    "start": "react-native start --port 8081",
    "start:lan": "react-native start --host 0.0.0.0 --port 8081",
    "android": "react-native run-android",
    "android:device": "react-native run-android --no-packager --active-arch-only",
    "android:apk:debug": "cd android && ./gradlew assembleDebug",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "android:aab:release": "cd android && ./gradlew bundleRelease",
    "android:install:debug": "cd android && ./gradlew installDebug",
    "android:install:release": "cd android && ./gradlew installRelease",
    "setup:android": "bash ./scripts/setup-android-env.sh",
    "setup:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-dev-short-path.ps1",
    "sync:stockdashboard": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-to-stockdashboard-mobile.ps1",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage --forceExit",
    "doctor": "react-native doctor",
    "check:parity": "node scripts/verify-mobile-parity.js",
    "check:pages": "node scripts/verify-pages.js",
    "check:signals-notify": "node scripts/verify-signal-notifications.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "react": "19.2.3",
    "react-native": "^0.85.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-webview": "^13.16.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/runtime": "^7.26.10",
    "@react-native-community/cli": "^20.0.2",
    "@react-native-community/cli-platform-android": "^20.0.2",
    "@react-native/eslint-config": "^0.85.2",
    "@react-native/jest-preset": "^0.85.2",
    "@react-native/metro-config": "^0.85.2",
    "@react-native/typescript-config": "^0.85.2",
    "@types/react": "^19.1.8",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "overrides": {
    "react": "19.2.3",
    "react-test-renderer": "19.2.3"
  }
}
