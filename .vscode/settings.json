{
  "python.defaultInterpreterPath": "${workspaceFolder}/../backend_stockdashboard/.venv/Scripts/python.exe",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/build": true,
    "**/.venv": true,
    "**/__pycache__": true
  },
  "eslint.workingDirectories": ["."],
  "javascript.preferences.quoteStyle": "single",
  "typescript.preferences.quoteStyle": "single"
}
