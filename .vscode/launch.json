{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome: React (localhost:3000)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src"
    },
    {
      "name": "Python: FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../backend_stockdashboard/.venv/Scripts/python.exe",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "${workspaceFolder}/../backend_stockdashboard",
      "jinja": true
    }
  ],
  "compounds": []
}
