# Core
DATABASE_URL=postgresql+psycopg2://stockapp:CHANGE_ME@127.0.0.1:5432/stockdb
SQLALCHEMY_DATABASE_URL=
ENABLE_ORCHESTRATOR=true
# Full data bootstrap runs and blocks orchestrator until done (every restart). See VPS_DATA_STALENESS.md §0
STARTUP_BOOTSTRAP_BEFORE_ORCHESTRATOR=true
STARTUP_BOOTSTRAP_TIMEOUT_SEC=7200
# Daily screen snapshots for Screens page (calendar days). Default 1095 (~3y); runs in background after API readiness.
STARTUP_SCREEN_SNAPSHOT_BACKFILL_DAYS=1095
# Subsector modal: persist CHG% from last two EOD candles into StockSectorInfo.day1d (fixes stale/wrong day1d). Default true.
STOCK_PERSIST_EOD_DAY1D=true
# Optional: also set price to last EOD close when price was missing (usually false; live quotes elsewhere).
# STOCK_PERSIST_EOD_LAST_CLOSE_AS_PRICE=false
BACKGROUND_REFRESH=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# Security/Auth
TOKEN_HASH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
AUTH_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
API_OBFUSCATION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
DHAN_TOKEN_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
AUTH_DEBUG_OTP=false
# Super-admin emails (admin UI, watchlist include-all, orders). Login: password + email OTP only (no passwordless admin shortcut).
AUTH_SUPER_ADMIN_EMAILS=gvc1990@gmail.com,admin@aycindustries.com
# Legacy alias (optional): same list if AUTH_SUPER_ADMIN_EMAILS unset
# AUTH_PASSWORDLESS_ADMIN_EMAILS=
# Trusted device: after OTP, skip email OTP for TRUSTED_DEVICE_DAYS on same browser (X-Device-Id). Default allows super-admins too.
TRUSTED_DEVICE_DAYS=7
AUTH_TRUSTED_DEVICE_FOR_SUPER_ADMIN=true
# Set false to force email OTP on every login for super-admin emails only.
# Rotating TOKEN_HASH_SECRET invalidates trusted-device recognition until users trust again.
LOGIN_LOCK_MINUTES=15
MAX_FAILED_LOGINS=5
PASSWORD_HASH_ITERATIONS=240000
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
ACCESS_TOKEN_TTL_SECONDS=1800
REFRESH_TOKEN_TTL_SECONDS=604800

# Dhan
DHAN_CLIENT_ID=
DHAN_API_KEY=
DHAN_API_SECRET=
DHAN_ADMIN_CLIENT_ID=
DHAN_LOGIN_BASE_URL=https://auth.dhan.co

# Samco / Market feeds
SAMCO_USER_ID=
SAMCO_PASSWORD=
SAMCO_YOB=
STRICT_SAMCO_FNO=true
SAMCO_WORKERS=6
SAMCO_PARALLEL_WORKERS=5
SAMCO_MIN_DELAY_SEC=0.3
SAMCO_GLOBAL_RPS=10
SIGNAL_SCAN_ENABLED=true
SIGNAL_SCAN_INTERVAL=10
CANDLE_FULL_LOOKBACK_DAYS=1200
CANDLE_INCR_LOOKBACK_DAYS=12
CANDLE_STOCK_DELAY=0.8
CANDLE_STOCK_DELAY_SECONDARY=0.15
CANDLE_INDEX_DELAY=0.5
ALWAYS_FETCH=false
DEBUG_LOGGING=false
WS_WARMUP_CHECK_SEC=20
WS_NO_TICK_FAILOVER_SEC=120

# Email/SMS — OTP emails: create mailbox support@aycindustries.com in Hostinger; use its SMTP password below
# NEVER put the real SMTP_PASSWORD in git — only in server-local backend_stockdashboard/.env (gitignored).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=support@aycindustries.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=support@aycindustries.com
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=
FAST2SMS_ROUTE=q

# Telegram/WhatsApp
ENABLE_TELEGRAM_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BROADCAST_DELAY_MS=60
TELEGRAM_INTERNAL_BACKEND=http://127.0.0.1:8010
ENABLE_WHATSAPP_NOTIFICATIONS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO_NUMBER=whatsapp:+91XXXXXXXXXX

# Optional LLM providers
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
PERPLEXITY_API_KEY=

# Hostinger API (optional — VPS/DNS automation via official Python SDK)
# SDK: https://github.com/hostinger/api-python-sdk  |  pip install hostinger_api
# Create token in hPanel → API; never commit the token.
HOSTINGER_API_TOKEN=
# ENABLE_HOSTINGER_API_ROUTES=true
# Optional: require header X-Hostinger-Secret on /api/hostinger/* (recommended if exposed)
# HOSTINGER_HTTP_SECRET=CHANGE_ME_LONG_RANDOM
